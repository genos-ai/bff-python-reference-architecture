# =============================================================================
# Secrets Template
# =============================================================================
# Copy this file to .env and fill in the values.
# This file contains ONLY secrets (passwords, tokens, keys).
# All other configuration lives in config/settings/*.yaml files.
# NEVER commit .env to version control.
# =============================================================================

# -- Database --
DB_PASSWORD=localdev

# -- Redis (empty for no auth) --
REDIS_PASSWORD=

# -- Security --
# JWT signing secret (generate with: openssl rand -hex 32)
APP_SECRET_KEY=

# API key encryption key (generate with: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())")
ENCRYPTION_KEY=

# -- Email (choose one) --
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
# OR
RESEND_API_KEY=

# -- Frontend --
FRONTEND_URL=http://localhost:5173
